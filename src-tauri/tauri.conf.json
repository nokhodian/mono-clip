{
  "productName": "MonoClip",
  "version": "0.2.1",
  "identifier": "com.monoes.monoclip",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && cargo build --bin mclip --release --manifest-path src-tauri/Cargo.toml && cp src-tauri/target/release/mclip src-tauri/binaries/mclip-$(rustc -Vv | grep host | cut -d' ' -f2)"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.monoclip/images/**"
        ]
      }
    },
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "MonoClip",
        "width": 680,
        "height": 520,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/mclip"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}