{
  "name": "monoclip",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mclip": "cargo build --bin mclip --release --manifest-path src-tauri/Cargo.toml && cp src-tauri/target/release/mclip \"src-tauri/binaries/mclip-$(rustc -Vv | grep host | cut -d' ' -f2)\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5",
    "@tauri-apps/cli": "^2",
    "autoprefixer": "^10",
    "svelte": "^5",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^6"
  }
}
